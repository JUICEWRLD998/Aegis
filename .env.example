# ── Terminal 3 ─────────────────────────────────────────────
# Claim from the T3 tokens claim page. CANNOT be retrieved after the success
# screen during testnet — store it safely. Auto-bound to your DID + test tokens.
T3N_API_KEY=

# Agent's own key (the agent authenticates as itself → its own did:t3n).
# If the agent reuses the developer key in testnet, set equal to T3N_API_KEY.
AGENT_KEY=

# "testnet" | "production"
T3N_ENV=testnet

# Tenant + contract coordinates (filled in after `register`)
TENANT_DID=
CONTRACT_TAIL=banking-contracts
CONTRACT_VERSION=0.1.0

# ── OpenRouter / Gemini ────────────────────────────────────
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.5-pro
OPENROUTER_MODEL_FALLBACK=google/gemini-2.5-flash

# ── App ────────────────────────────────────────────────────
NODE_ENV=development
